{
  "name": "blockchain-messaging",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:crypto": "npm run build -w packages/crypto",
    "build:blockchain": "npm run build -w packages/blockchain",
    "build:server": "npm run build -w packages/server",
    "build:client": "npm run build -w packages/client",
    "build": "npm run build:crypto && npm run build:blockchain && npm run build:server && npm run build:client",
    "dev:server": "npm run dev -w packages/server",
    "dev:blockchain": "npm run dev -w packages/blockchain",
    "dev:client": "npm run dev -w packages/client",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
