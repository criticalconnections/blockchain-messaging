# Database
DATABASE_URL=postgresql://bm_user:bm_password@postgres:5432/blockchain_messaging

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=change-me-in-production-use-256-bit-random-value
JWT_EXPIRES_IN=7d

# Blockchain node
BLOCKCHAIN_NODE_URL=http://blockchain-node:8001
BLOCKCHAIN_WS_URL=ws://blockchain-node:8001

# Server
PORT=3001
NODE_ENV=production

# Blockchain config
BLOCK_INTERVAL_MS=5000
MAX_BLOCK_SIZE=100
PRUNE_INTERVAL_MS=60000
